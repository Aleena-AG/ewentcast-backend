    },
    {
      "name": "Webhooks — Setup & Logs",
      "item": [
        {
          "name": "Get Webhook Setup Info",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-user-id", "value": "{{userId}}" }
            ],
            "url": "{{baseUrl}}/api/v1/webhooks/setup"
          }
        },
        {
          "name": "Register Webhooks (Luma + Eventbrite)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-id", "value": "{{userId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/api/v1/webhooks/setup",
            "description": "Registers webhook URLs on Luma + Eventbrite using saved settings credentials."
          }
        },
        {
          "name": "List Webhook Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-webhook-log-token", "value": "{{webhookLogToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/logs?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "logs"],
              "query": [{ "key": "limit", "value": "50" }]
            },
            "description": "Set WEBHOOK_LOG_TOKEN in .env to match {{webhookLogToken}}."
          }
        }
      ]
    }
  ]
}
